{
  "name": "pokeprice",
  "version": "1.0.0",
  "private": true,
  "description": "Pokemon card price tracker monorepo",
  "author": "Jason Wilson",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@pokeprice/web",
    "dev:desktop": "turbo dev --filter=@pokeprice/desktop",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=@pokeprice/desktop",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
